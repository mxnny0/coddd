const COURSES = {
  python:     { name:"Python",     file:"main.py",    runner:"py",   icon:"🐍", lessons:PY },
  javascript: { name:"JavaScript", file:"app.js",     runner:"js",   icon:"𝐉𝐒", lessons:JS },
  html:       { name:"HTML",       file:"index.html", runner:"html", icon:"🌐", lessons:HTML },
  css:        { name:"CSS",        file:"style.css",  runner:"css",  icon:"🎨", lessons:CSS }
};
const LANG_ORDER = ["python","javascript","html","css"];
const LEVELS = ["beginner","intermediate","advanced"];

/* =========================================================================
   PROFILES + STATE  (saved per-username in localStorage)
   ========================================================================= */
const LS_PROFILES="codeloop_profiles", LS_CURRENT="codeloop_current";
const dataKey = u => "codeloop_data_"+u;
let currentUser = null;

function getProfiles(){ try{ return JSON.parse(localStorage.getItem(LS_PROFILES)||"[]"); }catch(e){ return []; } }
function setProfiles(list){ try{ localStorage.setItem(LS_PROFILES, JSON.stringify(list)); }catch(e){} }

const state = {};
function resetState(){
  state.lang="python"; state.level="beginner";
  state.currentByLang={python:0,javascript:0,html:0,css:0};
  state.completed=new Set(); state.xp=0; state.combo=0; state.userCode={};
}
function loadState(){
  resetState();
  try{
    const raw = localStorage.getItem(dataKey(currentUser));
    if(raw){ const s=JSON.parse(raw);
      state.lang=s.lang||"python"; state.level=s.level||"beginner";
      state.currentByLang=Object.assign(state.currentByLang, s.currentByLang||{});
      state.completed=new Set(s.completed||[]); state.xp=s.xp||0; state.combo=s.combo||0;
      state.userCode=s.userCode||{};
    }
  }catch(e){}
}
function saveState(){
  if(!currentUser) return;
  try{ localStorage.setItem(dataKey(currentUser), JSON.stringify({
    lang:state.lang, level:state.level, currentByLang:state.currentByLang,
    completed:[...state.completed], xp:state.xp, combo:state.combo, userCode:state.userCode
  })); }catch(e){}
}

/* helpers */
const $ = id => document.getElementById(id);
let editor, _pvTimer;
function curCourse(){ return COURSES[state.lang]; }
function curLessons(){ return curCourse().lessons; }
function curIdx(){ return state.currentByLang[state.lang]; }
function setIdx(i){ state.currentByLang[state.lang]=i; }
function key(i){ return state.lang+":"+i; }
function runner(){ return curCourse().runner; }
function usesPreview(){ return runner()==="html"||runner()==="css"; }
function levelLessons(){ return curLessons().map((L,i)=>({L,i})).filter(x=>x.L.level===state.level); }

/* =========================================================================
   PROFILE UI
   ========================================================================= */
function renderProfileList(){
  const list=$("profileList"); list.innerHTML="";
  const profs=getProfiles();
  profs.forEach(u=>{
    const btn=document.createElement("button");
    btn.innerHTML=`<span class="av">${u[0].toUpperCase()}</span>${u} <span class="x" title="Delete">✕</span>`;
    btn.onclick=(e)=>{ if(e.target.classList.contains("x")){ e.stopPropagation(); deleteProfile(u); } else signIn(u); };
    list.appendChild(btn);
  });
  $("signedHint").textContent = currentUser ? ("Signed in as "+currentUser) : (profs.length?"":"No profiles yet — create one below.");
  $("closeOverlay").style.display = currentUser ? "inline" : "none";
}
function deleteProfile(u){
  if(!confirm(`Delete profile "${u}" and its progress?`)) return;
  setProfiles(getProfiles().filter(x=>x!==u));
  try{ localStorage.removeItem(dataKey(u)); }catch(e){}
  if(currentUser===u){ currentUser=null; try{localStorage.removeItem(LS_CURRENT);}catch(e){} }
  renderProfileList();
}
function signIn(u){
  u=(u||"").trim(); if(!u) return;
  const profs=getProfiles(); if(!profs.includes(u)){ profs.push(u); setProfiles(profs); }
  currentUser=u; try{ localStorage.setItem(LS_CURRENT,u); }catch(e){}
  loadState();
  $("overlay").classList.remove("show");
  $("chipName").textContent=u; $("avatar").textContent=u[0].toUpperCase();
  buildLangSwitch(); syncLevelTabs(); $("courseTitle").textContent=courseTitleText();
  buildTree(); renderLesson();
}
function showOverlay(){ renderProfileList(); $("newName").value=""; $("overlay").classList.add("show"); setTimeout(()=>$("newName").focus(),50); }
$("profileChip").onclick=showOverlay;
$("newGo").onclick=()=>signIn($("newName").value);
$("newName").addEventListener("keydown",e=>{ if(e.key==="Enter") signIn($("newName").value); });
$("closeOverlay").onclick=()=>{ if(currentUser) $("overlay").classList.remove("show"); };

/* =========================================================================
   SIDEBAR
   ========================================================================= */
function courseTitleText(){ return curCourse().name + (state.level==="beginner"?" Basics":state.level==="intermediate"?" — Intermediate":" — Advanced"); }
function buildLangSwitch(){
  const c=$("langSwitch"); c.innerHTML="";
  LANG_ORDER.forEach(lang=>{
    const b=document.createElement("button"); b.dataset.lang=lang;
    b.innerHTML=`<span>${COURSES[lang].icon}</span>${COURSES[lang].name}`;
    b.classList.toggle("active", lang===state.lang);
    b.onclick=()=>{ switchLang(lang); closeNav(); };
    c.appendChild(b);
  });
}
function syncLevelTabs(){ document.querySelectorAll("#levelSwitch button").forEach(b=>b.classList.toggle("active", b.dataset.level===state.level)); }
function buildTree(){
  const tree=$("tree"); tree.innerHTML="";
  const items=levelLessons();
  if(!items.length){ tree.innerHTML=`<div style="padding:18px;color:var(--faint);font-size:13px">More ${state.level} lessons coming soon in this language.</div>`; return; }
  let lastSec=null, secNum=0;
  items.forEach(({L,i})=>{
    if(L.sec!==lastSec){ lastSec=L.sec; secNum++;
      const s=document.createElement("div"); s.className="sec";
      s.innerHTML=`<div class="sec-name"><span class="n">${secNum}</span>${L.sec}</div>`; tree.appendChild(s); }
    const row=document.createElement("div");
    row.className="lrow"+(i===curIdx()?" active":"")+(state.completed.has(key(i))?" done":"");
    row.dataset.i=i; row.innerHTML=`<span class="dot"></span><span class="t">${L.title}</span>`;
    row.onclick=()=>{ goToFlat(i); closeNav(); };
    tree.lastChild.appendChild(row);
  });
}
function refreshProgress(){
  const items=levelLessons(); let done=0; items.forEach(({i})=>{ if(state.completed.has(key(i))) done++; });
  $("progFill").style.width=(items.length?done/items.length*100:0)+"%";
  $("doneCount").textContent=done; $("totalCount").textContent=items.length;
  $("xp").textContent=state.xp; $("combo").textContent=state.combo;
  document.querySelectorAll(".lrow").forEach(r=>{ const i=+r.dataset.i;
    r.classList.toggle("done", state.completed.has(key(i))); r.classList.toggle("active", i===curIdx()); });
}

/* =========================================================================
   RENDER LESSON
   ========================================================================= */
function modeFor(r){ return r==="py"?"python":r==="js"?"javascript":r==="css"?"css":{name:"xml",htmlMode:true}; }
function renderLesson(){
  const items=levelLessons();
  if(items.length && !items.some(x=>x.i===curIdx())) setIdx(items[0].i); // jump into level
  const L=curLessons()[curIdx()];
  if(!L){ return; }
  $("metaIdx").textContent="Lesson "+(items.findIndex(x=>x.i===curIdx())+1);
  $("metaSec").textContent=L.sec;
  const pill=$("lvlPill"); pill.textContent=L.level; pill.className="lvl-pill lvl-"+L.level;
  $("lessonTitle").textContent=L.title;
  $("concept").innerHTML=L.concept; $("task").innerHTML=L.task;
  $("solution").textContent=L.solution; $("solBox").open=false;

  editor.setOption("mode", modeFor(runner()));
  const saved=state.userCode[key(curIdx())];
  editor.setValue(saved!==undefined?saved:L.starter); editor.clearHistory();
  setTimeout(()=>editor.refresh(),0);

  $("fileName").textContent=curCourse().file;
  const live=usesPreview();
  $("panelLabel").textContent=live?"Live preview":"Console";
  $("liveTag").style.display=live?"inline":"none";
  $("runBtn").innerHTML=live?"✓ Check":"▸ Run";
  $("console").style.display=live?"none":"block";
  $("preview").style.display=live?"flex":"none";
  $("frame").setAttribute("sandbox", runner()==="css"?"allow-same-origin":"");
  clearPanel();
  if(live) updatePreview();

  $("aiOut").className="ai-out"; $("aiOut").innerHTML=""; $("aiInput").value="";
  $("prevBtn").disabled = items.length && items[0].i===curIdx();
  const next=$("nextBtn"), last=items.length && items[items.length-1].i===curIdx();
  next.textContent=last?"Level done 🎉":"Next →";
  next.classList.toggle("ready", state.completed.has(key(curIdx())));
  $("lessonScroll").scrollTop=0;
  refreshProgress(); saveState();
}
function goToFlat(i){ if(editor) state.userCode[key(curIdx())]=editor.getValue(); setIdx(i); renderLesson(); }
function moveLevelRel(dir){
  const items=levelLessons(); const pos=items.findIndex(x=>x.i===curIdx());
  const np=pos+dir; if(np<0||np>=items.length) return; goToFlat(items[np].i);
}
function switchLang(lang){
  if(editor) state.userCode[key(curIdx())]=editor.getValue();
  state.lang=lang;
  const L=curLessons()[curIdx()]; if(L) state.level=L.level;
  buildLangSwitch(); syncLevelTabs(); $("courseTitle").textContent=courseTitleText();
  buildTree(); renderLesson();
}
function setLevel(lvl){
  if(editor) state.userCode[key(curIdx())]=editor.getValue();
  state.level=lvl; syncLevelTabs();
  const items=levelLessons(); if(items.length) setIdx(items[0].i);
  $("courseTitle").textContent=courseTitleText(); buildTree(); renderLesson();
}

/* =========================================================================
   PANELS / OUTPUT
   ========================================================================= */
function clearPanel(){ const b=$("checkBadge"); b.className="check-badge"; b.textContent="";
  if(usesPreview()) $("htmlFeedback").classList.remove("show");
  else $("console").innerHTML=`<span class="muted">▸ Run your code to see the output here.</span>`; }
function logLine(t,cls){ const c=$("console"); if(c.querySelector(".muted")) c.innerHTML="";
  const s=document.createElement("span"); if(cls)s.className=cls; s.textContent=t+"\n"; c.appendChild(s); c.scrollTop=c.scrollHeight; }
function setBadge(p,t){ const b=$("checkBadge"); b.className="check-badge "+(p?"pass":"fail"); b.textContent=t; }
function normalize(s){ return (s||"").replace(/\r/g,"").split("\n").map(l=>l.replace(/\s+$/,"")).join("\n").replace(/\n+$/,"").replace(/^\n+/,""); }
function compact(s){ return (s||"").replace(/\s+/g,""); } // for array-style comparisons

/* live preview (html/css) */
function previewDocHTML(html){ return `<!doctype html><html><head><meta charset="utf-8"><style>
 body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#1a1f29;background:#fff;margin:0;padding:20px;line-height:1.55}
 h1{font-size:1.9em;margin:.2em 0}h2{font-size:1.4em;margin:.3em 0}a{color:#2563eb}img{max-width:100%}
 table{border-collapse:collapse}td{border:1px solid #cbd2dc;padding:6px 10px}
 .card{border:1px solid #e2e6ec;border-radius:12px;padding:18px;max-width:340px;box-shadow:0 6px 18px -10px rgba(0,0,0,.25)}
 input,button{font:inherit;padding:7px 11px;border-radius:8px;border:1px solid #cbd2dc;margin:3px 4px 3px 0}
 button{background:#1a1f29;color:#fff;border-color:#1a1f29;cursor:pointer}</style></head><body>${html}</body></html>`; }
function previewDocCSS(css,scaffold){ return `<!doctype html><html><head><meta charset="utf-8"><style>
 body{font-family:system-ui,-apple-system,sans-serif;color:#111;background:#fff;margin:0;padding:18px}
 ${css}</style></head><body>${scaffold||""}</body></html>`; }
function updatePreview(){ const L=curLessons()[curIdx()];
  $("frame").srcdoc = runner()==="css" ? previewDocCSS(editor.getValue(), L.scaffold) : previewDocHTML(editor.getValue()); }
function schedulePreview(){ clearTimeout(_pvTimer); _pvTimer=setTimeout(updatePreview,250); }

/* HTML check */
function checkHTML(){ const L=curLessons()[curIdx()]; state.userCode[key(curIdx())]=editor.getValue(); updatePreview();
  let ok=false; try{ ok=!!L.check(new DOMParser().parseFromString(editor.getValue(),"text/html").body); }catch(e){ ok=false; }
  finishCheck(ok,L); }
/* CSS check (async — render then read computed styles) */
function checkCSS(){ const L=curLessons()[curIdx()]; state.userCode[key(curIdx())]=editor.getValue();
  const f=$("frame"); f.onload=()=>{ let ok=false; try{ ok=!!L.check(f.contentDocument, f.contentWindow); }catch(e){ ok=false; } finishCheck(ok,L); };
  f.srcdoc=previewDocCSS(editor.getValue(), L.scaffold); }
function finishCheck(ok,L){ const fb=$("htmlFeedback");
  if(ok){ setBadge(true,"✓ Passed"); fb.classList.remove("show"); onPass(); }
  else{ setBadge(false,"Not yet"); fb.textContent="Hint: "+L.failHint; fb.classList.add("show"); } }

/* JavaScript run */
function fmtJS(v){ if(typeof v==="string") return v; try{ return JSON.stringify(v); }catch(e){ return String(v); } }
function runJSCapture(code){ const logs=[];
  const c={ log:(...a)=>logs.push(a.map(fmtJS).join(" ")), error:(...a)=>logs.push(a.map(fmtJS).join(" ")),
            warn:(...a)=>logs.push(a.map(fmtJS).join(" ")), info:(...a)=>logs.push(a.map(fmtJS).join(" ")) };
  let err=null;
  try{ new Function("console", code)(c); }
  catch(e){ err=(e&&e.message)?(e.name+": "+e.message):String(e); }
  return {out:logs.join("\n"), err}; }
function runJS(){ const L=curLessons()[curIdx()]; state.userCode[key(curIdx())]=editor.getValue(); clearPanel();
  const {out,err}=runJSCapture(editor.getValue()); $("console").innerHTML="";
  if(err){ logLine(err,"err"); setBadge(false,"Error"); return; }
  if(out.length) out.split("\n").forEach(l=>logLine(l)); else logLine("(no output)","muted");
  let ok = L.expected===undefined ? true : (normalize(out)===normalize(L.expected) || compact(out)===compact(L.expected));
  if(ok && L.mustInclude) ok = L.mustInclude.every(s=>editor.getValue().includes(s));
  if(ok){ setBadge(true,"✓ Passed"); onPass(); }
  else{ setBadge(false,"Not yet"); logLine("",null);
    if(L.expected!==undefined && normalize(out)!==normalize(L.expected)){ logLine("Expected output:","want"); normalize(L.expected).split("\n").forEach(l=>logLine("  "+l,"want")); }
    logLine("Hint: "+L.failHint,"sys"); } }

/* Python run */
let pyodide=null, pyLoading=null;
const RUNNER=`
import sys, io, traceback, json
def __run(src, test):
    buf=io.StringIO(); old=sys.stdout; sys.stdout=buf
    ns={"__name__":"__main__"}; ue=None; te=None
    try: exec(src, ns)
    except Exception: ue=traceback.format_exc(limit=1)
    if ue is None and test:
        try: exec(test, ns)
        except Exception: te="fail"
    sys.stdout=old
    return json.dumps({"out":buf.getvalue(),"ue":ue,"te":te})
`;
async function ensurePy(){ if(pyodide) return pyodide; if(pyLoading) return pyLoading;
  logLine("Booting the Python engine — one-time, ~10s…","sys");
  pyLoading=(async()=>{ if(!window.loadPyodide){ await new Promise((res,rej)=>{ const s=document.createElement("script");
    s.src="https://cdn.jsdelivr.net/pyodide/v0.26.4/full/pyodide.js"; s.onload=res; s.onerror=()=>rej(new Error("load")); document.head.appendChild(s); }); }
    pyodide=await loadPyodide({indexURL:"https://cdn.jsdelivr.net/pyodide/v0.26.4/full/"}); pyodide.runPython(RUNNER); return pyodide; })();
  return pyLoading; }
async function runPy(){ const L=curLessons()[curIdx()]; state.userCode[key(curIdx())]=editor.getValue();
  const rb=$("runBtn"); rb.disabled=true; clearPanel();
  let py; try{ py=await ensurePy(); }catch(e){ logLine("Couldn't load the Python engine — check your connection and try again.","err"); rb.disabled=false; return; }
  let res; try{ py.globals.set("__src",editor.getValue()); py.globals.set("__test",L.test||""); res=JSON.parse(py.runPython("__run(__src, __test)")); }
  catch(e){ logLine("Internal error.","err"); rb.disabled=false; return; }
  $("console").innerHTML=""; rb.disabled=false;
  if(res.ue){ res.ue.trim().split("\n").forEach(l=>logLine(l,"err")); setBadge(false,"Error"); return; }
  const out=res.out; if(out.length) out.replace(/\n$/,"").split("\n").forEach(l=>logLine(l)); else logLine("(no output)","muted");
  const ok=(L.expected===undefined?true:normalize(out)===normalize(L.expected)) && !res.te;
  if(ok){ setBadge(true,"✓ Passed"); onPass(); }
  else{ setBadge(false,"Not yet"); logLine("",null);
    if(L.expected!==undefined && normalize(out)!==normalize(L.expected)){ logLine("Expected output:","want"); normalize(L.expected).split("\n").forEach(l=>logLine("  "+l,"want")); }
    logLine("Hint: "+L.failHint,"sys"); } }

function runAndCheck(){ const r=runner(); if(r==="py") return runPy(); if(r==="js") return runJS(); if(r==="html") return checkHTML(); if(r==="css") return checkCSS(); }

/* pass / progress */
function onPass(){ const k=key(curIdx()); const first=!state.completed.has(k); state.completed.add(k);
  if(first){ state.xp+=20; state.combo+=1; showToast(`Passed! +20 XP · 🔥 ${state.combo} combo`); } else showToast("Passed! ✓");
  $("nextBtn").classList.add("ready"); refreshProgress(); saveState(); }
$("solBox").addEventListener("toggle",function(){ if(this.open && state.combo>0){ state.combo=0; refreshProgress(); saveState(); } });
function showToast(m){ const t=$("toast"); t.textContent=m; t.classList.add("show"); clearTimeout(showToast._t); showToast._t=setTimeout(()=>t.classList.remove("show"),2400); }

/* AI tutor */
async function callClaude(content){ const ep=AI_PROXY_URL||"https://api.anthropic.com/v1/messages";
  const res=await fetch(ep,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({
    model:"claude-sonnet-4-20250514",max_tokens:1000,
    system:"You are Codeloop's built-in tutor for someone learning to code (Python, JavaScript, HTML, or CSS). Warm, brief, encouraging, plain language, tiny snippets only. Never write the full solution — nudge toward it. Under 90 words.",
    messages:[{role:"user",content}]})});
  if(!res.ok) throw new Error("api "+res.status); const d=await res.json();
  return (d.content||[]).map(b=>b.type==="text"?b.text:"").join("\n").trim(); }
function aiThinking(){ const o=$("aiOut"); o.className="ai-out show"; o.innerHTML=`<span class="ai-thinking"><i></i><i></i><i></i> thinking…</span>`; }
function aiShow(t,tip){ const o=$("aiOut"); o.className="ai-out show"+(tip?" tip":""); o.textContent=t; }
function aiErr(){ aiShow("The AI tutor couldn't be reached. The built-in hints still work — try the check, or come back in a moment.",false); }
function ctx(){ const L=curLessons()[curIdx()]; const lang=curCourse().name;
  return `Language: ${lang}\nLesson: "${L.title}"\nGoal: ${L.task.replace(/<[^>]+>/g,"")}\n\nStudent's code:\n\`\`\`\n${editor.getValue()}\n\`\`\``; }
$("hintBtn").onclick=async()=>{ aiThinking(); try{ aiShow(await callClaude(ctx()+`\n\nGive ONE short hint (2-3 sentences) nudging them forward. Don't give the full answer.`),true); }catch(e){ aiErr(); } };
$("explainBtn").onclick=async()=>{ const L=curLessons()[curIdx()]; aiThinking(); try{ aiShow(await callClaude(`Explain the idea in "${L.title}" to a beginner in 3-4 short sentences with one tiny example. Concept: ${L.concept.replace(/<[^>]+>/g," ").replace(/\s+/g," ").trim().slice(0,520)}`),false); }catch(e){ aiErr(); } };
async function askAI(){ const q=$("aiInput").value.trim(); if(!q) return; $("aiInput").value=""; aiThinking();
  try{ aiShow(await callClaude(ctx()+`\n\nThe student asks: "${q}"\nAnswer briefly; guide rather than pasting the full solution.`),false); }catch(e){ aiErr(); } }
$("askBtn").onclick=askAI; $("aiInput").addEventListener("keydown",e=>{ if(e.key==="Enter") askAI(); });

/* wiring */
$("runBtn").onclick=runAndCheck;
$("resetBtn").onclick=()=>{ editor.setValue(curLessons()[curIdx()].starter); clearPanel(); if(usesPreview()) updatePreview(); editor.focus(); };
$("prevBtn").onclick=()=>moveLevelRel(-1);
$("nextBtn").onclick=()=>{ const items=levelLessons(); if(items.length && items[items.length-1].i!==curIdx()) moveLevelRel(1); else showToast("🎉 Level complete!"); };
document.querySelectorAll("#levelSwitch button").forEach(b=>b.onclick=()=>{ setLevel(b.dataset.level); closeNav(); });
function openNav(){ $("sidebar").classList.add("open"); $("scrim").classList.add("show"); }
function closeNav(){ $("sidebar").classList.remove("open"); $("scrim").classList.remove("show"); }
$("navToggle").onclick=()=> $("sidebar").classList.contains("open")?closeNav():openNav();
$("scrim").onclick=closeNav;
document.addEventListener("keydown",e=>{ if((e.ctrlKey||e.metaKey)&&e.key==="Enter"){ e.preventDefault(); runAndCheck(); } });

/* boot */
(function init(){
  editor=CodeMirror.fromTextArea($("code"),{ mode:"python", theme:"material-darker", lineNumbers:true,
    indentUnit:2, tabSize:2, indentWithTabs:false, lineWrapping:true, extraKeys:{ "Tab":cm=>cm.replaceSelection("  ") } });
  editor.on("change",()=>{ if(usesPreview()) schedulePreview(); });
  resetState(); buildLangSwitch(); syncLevelTabs();
  let saved=null; try{ saved=localStorage.getItem(LS_CURRENT); }catch(e){}
  const profs=getProfiles();
  if(saved && profs.includes(saved)){ signIn(saved); }
  else{ $("courseTitle").textContent=courseTitleText(); buildTree(); renderLesson(); showOverlay(); }
})();
