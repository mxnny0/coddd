<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Codeloop — Learn to code, free & unlimited</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/theme/material-darker.min.css">
<style>
  :root{
    --bg:#0c1015; --panel:#12171f; --panel-2:#0f141b; --raised:#1a212c;
    --border:#222c38; --border-soft:#1a222c;
    --text:#e7eef6; --muted:#8a97a7; --faint:#5a6573;
    --accent:#a3e635; --accent-deep:#7bb918; --accent-dim:rgba(163,230,53,.13);
    --amber:#fbbf24; --blue:#5aa9ff; --red:#ff7a7a; --ok:#46c463;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --disp:"Space Grotesk",system-ui,sans-serif;
    --ui:"Inter",system-ui,-apple-system,sans-serif;
  }
  *{box-sizing:border-box}
  html,body{height:100%}
  body{margin:0;background:var(--bg);color:var(--text);font-family:var(--ui);font-size:15px;line-height:1.55;-webkit-font-smoothing:antialiased;overflow:hidden}
  ::selection{background:var(--accent-dim)}
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
  button:focus-visible,a:focus-visible,input:focus-visible,summary:focus-visible{outline:2px solid var(--accent);outline-offset:2px;border-radius:6px}
  code{font-family:var(--mono)}
  #app{display:flex;flex-direction:column;height:100dvh}

  .topbar{display:flex;align-items:center;gap:14px;height:56px;flex:0 0 56px;padding:0 16px;background:linear-gradient(180deg,#11161e,#0e131a);border-bottom:1px solid var(--border)}
  .nav-toggle{display:none;font-size:20px;width:38px;height:38px;border-radius:9px}
  .nav-toggle:hover{background:var(--raised)}
  .brand{display:flex;align-items:center;gap:10px;font-family:var(--disp);font-weight:700;font-size:18px;letter-spacing:-.01em}
  .brand .mark{width:30px;height:30px;border-radius:8px;display:grid;place-items:center;background:var(--accent);color:#0a0d11;font-weight:700;font-size:15px;font-family:var(--mono);box-shadow:0 0 0 1px rgba(163,230,53,.4),0 6px 18px -6px var(--accent)}
  .brand .mark::after{content:"{ }"}
  .brand .loop{color:var(--accent)}
  .stats{margin-left:auto;display:flex;align-items:center;gap:9px}
  .stat{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:13px;font-weight:500;background:var(--raised);padding:6px 11px;border-radius:999px;border:1px solid var(--border-soft)}
  .stat.xp b{color:var(--accent)} .stat.combo b{color:var(--amber)}
  .profile-chip{display:flex;align-items:center;gap:7px;background:var(--raised);border:1px solid var(--border-soft);padding:5px 12px 5px 6px;border-radius:999px;font-weight:600;font-size:13px;transition:.12s}
  .profile-chip:hover{border-color:var(--accent)}
  .profile-chip .av{width:24px;height:24px;border-radius:50%;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),#d6f56b);color:#0a0d11;font-weight:700;font-size:12px;font-family:var(--disp)}

  .body{flex:1;display:flex;min-height:0}
  .sidebar{flex:0 0 282px;width:282px;background:var(--panel-2);border-right:1px solid var(--border);display:flex;flex-direction:column;min-height:0}
  .course-head{padding:14px 16px 12px;border-bottom:1px solid var(--border-soft)}
  .seg{display:flex;gap:4px;background:var(--raised);padding:4px;border-radius:11px}
  .seg.lang{margin-bottom:9px;flex-wrap:wrap}
  .seg button{flex:1 1 0;min-width:0;padding:7px 5px;border-radius:8px;font-family:var(--disp);font-weight:600;font-size:12.5px;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:5px;transition:.12s;white-space:nowrap}
  .seg button.active{background:var(--accent);color:#0a0d11}
  .seg button:not(.active):hover{color:var(--text)}
  .seg.level{margin-bottom:12px}
  .seg.level button{font-size:11.5px;padding:6px 4px}
  .course-eyebrow{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);font-weight:600}
  .course-title{font-family:var(--disp);font-size:17px;font-weight:600;margin:3px 0 11px}
  .progress{height:7px;border-radius:99px;background:var(--raised);overflow:hidden}
  .progress > i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--accent-deep),var(--accent));transition:width .5s cubic-bezier(.2,.8,.2,1)}
  .progress-label{margin-top:7px;font-size:12px;color:var(--muted);font-family:var(--mono)}
  .progress-label b{color:var(--text)}
  .tree{flex:1;overflow-y:auto;padding:4px 10px 22px}
  .sec{margin-top:14px}
  .sec-name{display:flex;align-items:center;gap:8px;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--faint);font-weight:600;padding:6px 8px}
  .sec-name .n{width:18px;height:18px;border-radius:5px;background:var(--raised);display:grid;place-items:center;font-family:var(--mono);font-size:11px;color:var(--muted)}
  .lrow{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:9px;cursor:pointer;color:var(--muted);font-size:13.5px;font-weight:500;transition:background .12s,color .12s}
  .lrow:hover{background:var(--raised);color:var(--text)}
  .lrow.active{background:var(--accent-dim);color:var(--text)}
  .lrow.active .dot{border-color:var(--accent)}
  .dot{flex:0 0 18px;width:18px;height:18px;border-radius:50%;border:2px solid var(--border);display:grid;place-items:center;font-size:11px;transition:.15s}
  .lrow.done .dot{background:var(--accent);border-color:var(--accent);color:#0a0d11}
  .lrow.done .dot::after{content:"✓";font-weight:700}
  .lrow .t{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

  .main{flex:1;display:flex;min-width:0}
  .lesson-pane{flex:0 0 44%;max-width:560px;min-width:330px;display:flex;flex-direction:column;background:var(--panel);border-right:1px solid var(--border);min-height:0}
  .lesson-scroll{flex:1;overflow-y:auto;padding:24px 30px 28px}
  .lesson-meta{font-size:12px;font-family:var(--mono);color:var(--faint);letter-spacing:.02em}
  .lesson-meta b{color:var(--accent)}
  .lvl-pill{display:inline-block;font-size:10px;letter-spacing:.08em;text-transform:uppercase;font-weight:700;padding:2px 7px;border-radius:99px;margin-left:6px;vertical-align:middle}
  .lvl-beginner{background:rgba(70,196,99,.16);color:#7ee29a}
  .lvl-intermediate{background:rgba(90,169,255,.16);color:#8ec5ff}
  .lvl-advanced{background:rgba(251,191,36,.16);color:#fbbf24}
  h1.lesson-title{font-family:var(--disp);font-size:25px;font-weight:600;letter-spacing:-.02em;margin:7px 0 16px;line-height:1.2}
  .concept{color:#cdd6e0;font-size:14.5px}
  .concept p{margin:0 0 13px}
  .concept code{background:var(--raised);padding:2px 6px;border-radius:5px;font-size:12.5px;color:#dbe9c4;border:1px solid var(--border-soft)}
  .ex{background:var(--panel-2);border:1px solid var(--border);border-radius:10px;margin:0 0 14px;overflow:hidden}
  .ex .ex-label{display:block;font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--faint);padding:8px 12px 0}
  .ex pre{margin:0;padding:6px 14px 13px;font-family:var(--mono);font-size:13px;color:#e7eef6;white-space:pre-wrap;line-height:1.5}
  .ex pre .o{color:var(--faint)}
  .challenge{margin:22px 0 6px;border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:10px;background:linear-gradient(90deg,var(--accent-dim),transparent 70%);padding:14px 16px}
  .challenge .ctitle{font-family:var(--disp);font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);margin-bottom:5px;display:flex;align-items:center;gap:7px}
  .challenge .task{color:#dfe7f0;font-size:14.5px}
  .challenge .task code{background:rgba(255,255,255,.06)}
  details.solution{margin:16px 0 4px;border:1px solid var(--border);border-radius:10px;background:var(--panel-2)}
  details.solution summary{list-style:none;cursor:pointer;padding:11px 14px;font-size:13px;font-weight:600;color:var(--muted);display:flex;align-items:center;gap:8px}
  details.solution summary::-webkit-details-marker{display:none}
  details.solution summary:hover{color:var(--text)}
  details.solution summary .chev{transition:.2s;color:var(--faint)}
  details.solution[open] summary .chev{transform:rotate(90deg)}
  details.solution .sol-note{font-size:11.5px;color:var(--faint);font-weight:400;margin-left:auto}
  details.solution pre{margin:0;padding:0 14px 14px;font-family:var(--mono);font-size:13px;color:#dbe9c4;white-space:pre-wrap}
  .ai{margin-top:22px;border:1px solid var(--border);border-radius:12px;background:var(--panel-2);overflow:hidden}
  .ai-head{display:flex;align-items:center;gap:9px;padding:12px 15px;border-bottom:1px solid var(--border-soft)}
  .ai-head .orb{width:22px;height:22px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#d6f56b,var(--accent-deep));box-shadow:0 0 12px -2px var(--accent)}
  .ai-head .ttl{font-family:var(--disp);font-weight:600;font-size:14px}
  .ai-head .sub{font-size:11px;color:var(--faint);margin-left:auto}
  .ai-body{padding:13px 15px}
  .ai-actions{display:flex;gap:8px;flex-wrap:wrap}
  .btn-ghost{background:var(--raised);border:1px solid var(--border);padding:8px 13px;border-radius:9px;font-size:13px;font-weight:600;color:var(--text);transition:.12s}
  .btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
  .ai-out{margin-top:12px;font-size:13.5px;color:#d3dce6;white-space:pre-wrap;line-height:1.55;display:none}
  .ai-out.show{display:block}
  .ai-out.tip{border-left:2px solid var(--amber);padding-left:12px}
  .ai-thinking{display:flex;gap:5px;align-items:center;color:var(--muted);font-size:13px}
  .ai-thinking i{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:blink 1.2s infinite both}
  .ai-thinking i:nth-child(2){animation-delay:.2s}.ai-thinking i:nth-child(3){animation-delay:.4s}
  @keyframes blink{0%,80%,100%{opacity:.2}40%{opacity:1}}
  .ai-ask{display:flex;gap:8px;margin-top:12px}
  .ai-ask input{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:9px 12px;color:var(--text);font-family:inherit;font-size:13px}
  .ai-ask input::placeholder{color:var(--faint)}
  .ai-ask button{flex:0 0 auto;background:var(--accent);color:#0a0d11;font-weight:600;padding:9px 15px;border-radius:9px;font-size:13px}
  .ai-ask button:hover{background:#b6f04a}
  .lesson-foot{flex:0 0 auto;display:flex;gap:10px;padding:13px 22px;border-top:1px solid var(--border);background:var(--panel)}
  .lesson-foot button{flex:1;padding:11px;border-radius:10px;font-weight:600;font-size:14px;transition:.12s}
  #prevBtn{background:var(--raised);border:1px solid var(--border);color:var(--muted)}
  #prevBtn:hover:not(:disabled){color:var(--text)} #prevBtn:disabled{opacity:.4;cursor:not-allowed}
  #nextBtn{background:var(--raised);border:1px solid var(--border);color:var(--text)}
  #nextBtn.ready{background:var(--accent);color:#0a0d11;border-color:var(--accent);box-shadow:0 0 22px -6px var(--accent)}
  #nextBtn.ready:hover{background:#b6f04a}

  .editor-pane{flex:1;display:flex;flex-direction:column;min-width:0;background:var(--panel-2)}
  .editor-bar{display:flex;align-items:center;gap:10px;height:46px;flex:0 0 46px;padding:0 14px;border-bottom:1px solid var(--border);background:var(--panel)}
  .filetab{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:13px;color:var(--muted)}
  .filetab .py{width:9px;height:9px;border-radius:50%;background:var(--accent)}
  .editor-bar .spacer{flex:1}
  .ebtn{padding:7px 13px;border-radius:8px;font-size:13px;font-weight:600;transition:.12s}
  #resetBtn{color:var(--muted)}#resetBtn:hover{color:var(--text);background:var(--raised)}
  #runBtn{background:var(--accent);color:#0a0d11;display:flex;align-items:center;gap:6px}
  #runBtn:hover{background:#b6f04a} #runBtn:disabled{opacity:.55;cursor:wait}
  .editor-wrap{flex:1;min-height:0;position:relative}
  .CodeMirror{height:100%!important;font-family:var(--mono)!important;font-size:14px!important;background:var(--panel-2)!important;line-height:1.6!important}
  .CodeMirror-gutters{background:var(--panel-2)!important;border-right:1px solid var(--border-soft)!important}
  .CodeMirror-linenumber{color:#3c4654!important}
  .CodeMirror-cursor{border-left:1.5px solid var(--accent)!important}
  .CodeMirror-selected{background:rgba(163,230,53,.12)!important}
  .console-bar{display:flex;align-items:center;gap:10px;height:38px;flex:0 0 38px;padding:0 14px;border-top:1px solid var(--border);background:var(--panel);font-family:var(--mono);font-size:12px;color:var(--muted)}
  .console-bar .dotg{width:7px;height:7px;border-radius:50%;background:var(--faint)}
  .live-tag{font-size:10px;color:var(--accent);border:1px solid var(--accent-dim);background:var(--accent-dim);padding:1px 7px;border-radius:99px}
  .check-badge{margin-left:auto;font-weight:600;font-size:12px;padding:3px 10px;border-radius:99px;display:none}
  .check-badge.pass{display:inline-block;color:#0a0d11;background:var(--ok)}
  .check-badge.fail{display:inline-block;color:#0a0d11;background:var(--amber)}
  .panel-wrap{flex:0 0 42%;min-height:150px;display:flex;flex-direction:column;min-height:0}
  .console{flex:1;overflow-y:auto;padding:12px 16px;font-family:var(--mono);font-size:13px;line-height:1.6;background:var(--bg);white-space:pre-wrap}
  .console .muted{color:var(--faint)} .console .err{color:var(--red)} .console .ok{color:var(--accent);font-weight:600}
  .console .sys{color:var(--blue)} .console .want{color:var(--amber)}
  .preview{flex:1;display:flex;flex-direction:column;min-height:0;background:#fff}
  .html-feedback{display:none;font-family:var(--mono);font-size:12.5px;color:#0a0d11;background:var(--amber);padding:8px 14px}
  .html-feedback.show{display:block}
  .preview iframe{flex:1;width:100%;border:none;background:#fff}

  .toast{position:fixed;left:50%;bottom:26px;transform:translate(-50%,80px);background:var(--ok);color:#08110a;font-weight:700;padding:12px 22px;border-radius:12px;font-size:15px;box-shadow:0 18px 40px -12px rgba(0,0,0,.6);opacity:0;transition:.35s cubic-bezier(.2,.9,.2,1);z-index:60;display:flex;align-items:center;gap:9px}
  .toast.show{transform:translate(-50%,0);opacity:1}

  /* profile overlay */
  .overlay{position:fixed;inset:0;z-index:80;display:none;place-items:center;background:rgba(8,11,15,.86);backdrop-filter:blur(4px)}
  .overlay.show{display:grid}
  .signin{width:min(420px,92vw);background:var(--panel);border:1px solid var(--border);border-radius:18px;padding:28px;box-shadow:0 30px 80px -20px rgba(0,0,0,.7)}
  .signin .logo{display:flex;align-items:center;gap:10px;font-family:var(--disp);font-weight:700;font-size:20px;margin-bottom:4px}
  .signin .logo .mark{width:32px;height:32px;border-radius:9px;display:grid;place-items:center;background:var(--accent);color:#0a0d11;font-family:var(--mono);font-weight:700}
  .signin .logo .mark::after{content:"{ }"}
  .signin h2{font-family:var(--disp);font-size:18px;margin:14px 0 4px}
  .signin p{color:var(--muted);font-size:13.5px;margin:0 0 16px}
  .profile-list{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
  .profile-list button{display:flex;align-items:center;gap:8px;background:var(--raised);border:1px solid var(--border);padding:8px 12px;border-radius:10px;font-weight:600;font-size:13.5px;transition:.12s}
  .profile-list button:hover{border-color:var(--accent);color:var(--accent)}
  .profile-list button .av{width:22px;height:22px;border-radius:50%;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),#d6f56b);color:#0a0d11;font-weight:700;font-size:11px}
  .profile-list button .x{margin-left:2px;color:var(--faint);font-weight:700}
  .profile-list button .x:hover{color:var(--red)}
  .signin .newrow{display:flex;gap:8px}
  .signin input{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:11px 13px;color:var(--text);font-family:inherit;font-size:14px}
  .signin input::placeholder{color:var(--faint)}
  .signin .go{flex:0 0 auto;background:var(--accent);color:#0a0d11;font-weight:700;padding:11px 18px;border-radius:10px}
  .signin .go:hover{background:#b6f04a}
  .signin .foot{display:flex;justify-content:space-between;align-items:center;margin-top:16px;font-size:12.5px;color:var(--faint)}
  .signin .foot a{color:var(--muted);cursor:pointer;text-decoration:underline}

  .scrim{display:none}
  @media (max-width:1080px){ .lesson-pane{flex-basis:50%} }
  @media (max-width:860px){
    .nav-toggle{display:grid;place-items:center}
    .sidebar{position:fixed;z-index:40;top:56px;bottom:0;left:0;transform:translateX(-100%);transition:transform .25s;box-shadow:0 0 60px rgba(0,0,0,.5)}
    .sidebar.open{transform:none}
    .scrim{display:block;position:fixed;inset:56px 0 0 0;background:rgba(0,0,0,.5);z-index:39;opacity:0;pointer-events:none;transition:.25s}
    .scrim.show{opacity:1;pointer-events:auto}
    .main{flex-direction:column}
    .lesson-pane{flex:0 0 auto;max-width:none;min-width:0;max-height:48%;border-right:none;border-bottom:1px solid var(--border)}
    .editor-pane{flex:1}
    .stat.combo{display:none}
  }
  ::-webkit-scrollbar{width:10px;height:10px}
  ::-webkit-scrollbar-thumb{background:#222c38;border-radius:99px;border:3px solid transparent;background-clip:padding-box}
  ::-webkit-scrollbar-thumb:hover{background:#30404f;border:3px solid transparent;background-clip:padding-box}
  @media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>
<div id="app">
  <header class="topbar">
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">☰</button>
    <div class="brand"><span class="mark" aria-hidden="true"></span><span>Code<span class="loop">loop</span></span></div>
    <div class="stats">
      <div class="stat xp" title="Experience points"><span>⚡</span><b id="xp">0</b><span>XP</span></div>
      <div class="stat combo" title="Pass lessons in a row to build a combo. Revealing a solution resets it."><span>🔥</span><b id="combo">0</b></div>
      <button class="profile-chip" id="profileChip" title="Switch profile"><span class="av" id="avatar">?</span><span id="chipName">Sign in</span></button>
    </div>
  </header>
  <div class="body">
    <aside class="sidebar" id="sidebar">
      <div class="course-head">
        <div class="seg lang" id="langSwitch"></div>
        <div class="seg level" id="levelSwitch">
          <button data-level="beginner" class="active">Beginner</button>
          <button data-level="intermediate">Intermediate</button>
          <button data-level="advanced">Advanced</button>
        </div>
        <div class="course-eyebrow">Course</div>
        <div class="course-title" id="courseTitle"></div>
        <div class="progress"><i id="progFill"></i></div>
        <div class="progress-label"><b id="doneCount">0</b> / <span id="totalCount">0</span> in this level</div>
      </div>
      <nav class="tree" id="tree" aria-label="Lessons"></nav>
    </aside>
    <div class="scrim" id="scrim"></div>
    <main class="main">
      <section class="lesson-pane">
        <div class="lesson-scroll" id="lessonScroll">
          <div class="lesson-meta"><b id="metaIdx">Lesson 1</b> · <span id="metaSec"></span><span class="lvl-pill" id="lvlPill"></span></div>
          <h1 class="lesson-title" id="lessonTitle"></h1>
          <div class="concept" id="concept"></div>
          <div class="challenge"><div class="ctitle">▸ Your challenge</div><div class="task" id="task"></div></div>
          <details class="solution" id="solBox"><summary><span class="chev">▸</span> Show solution <span class="sol-note">resets your 🔥 combo</span></summary><pre id="solution"></pre></details>
          <div class="ai">
            <div class="ai-head"><span class="orb" aria-hidden="true"></span><span class="ttl">AI tutor</span><span class="sub">unlimited</span></div>
            <div class="ai-body">
              <div class="ai-actions"><button class="btn-ghost" id="hintBtn">💡 Get a hint</button><button class="btn-ghost" id="explainBtn">📖 Explain this lesson</button></div>
              <div class="ai-out" id="aiOut"></div>
              <div class="ai-ask"><input id="aiInput" placeholder="Ask the tutor anything…" autocomplete="off"><button id="askBtn">Ask</button></div>
            </div>
          </div>
        </div>
        <div class="lesson-foot"><button id="prevBtn">← Back</button><button id="nextBtn">Next →</button></div>
